---
import { galleryImages } from '../data/images';
const { limit = galleryImages.length } = Astro.props;
const imgs = galleryImages.filter((x) => !x.endsWith('.ico')).slice(0, limit);
---
<div class="gallery-grid">
  {imgs.map((img, i) => (
    <figure class={i % 7 === 0 ? 'wide' : i % 5 === 0 ? 'tall' : ''}>
      <img src={`/images/${img}`} alt={`Referenzarbeit RaumDesign Rudek ${i + 1}`} loading="lazy" />
    </figure>
  ))}
</div>
