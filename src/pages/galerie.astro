---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
---
<BaseLayout title="Galerie" description="Referenzbilder von RaumDesign Rudek: Kalkputz, Lasuren, kreative Wandgestaltung und Renovierungsarbeiten.">
  <section class="gallery-head"><p class="eyebrow">Galerie</p><h1>Oberflächen, Farben und Räume aus echten Projekten.</h1><p>Ein Großteil der verwendeten Materialien stammt direkt aus Italien, Marokko oder Großbritannien. Die Basis sind häufig mineralische Kalkputze — ein klassischer Werkstoff mit moderner Wirkung.</p></section>
  <GalleryGrid />
</BaseLayout>
