---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { featureImages } from '../data/images';
import { services, site } from '../data/site';
---
<BaseLayout title="RaumDesign Rudek" description="Kreative Raum- und Wandgestaltung, Edelputze, Lasuren und Malerarbeiten in Düsseldorf.">
  <section class="hero">
    <img src={featureImages.hero} alt="Edle Wandoberfläche mit Glitzerputz und Lasur" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">Malerfachbetrieb Düsseldorf</p>
      <h1>Wände, die nicht nur gestrichen sind. Sondern gestaltet.</h1>
      <p>RaumDesign Rudek verbindet klassische Malerarbeit mit Kalkputz, Lasuren, Marmorputz und fein abgestimmten Farbkonzepten.</p>
      <div class="hero-actions"><a class="btn primary" href={site.phoneHref}>0162/9353172</a><a class="btn ghost" href="/galerie/">Arbeiten ansehen</a></div>
    </div>
    <aside class="hero-card" aria-label="Spezialisierungen"><span>Kalkputz</span><span>Lasuren</span><span>Edeltechniken</span><span>Farbkonzepte</span></aside>
  </section>
  <section class="trust-strip"><div><strong>Ökologisch</strong><span>mineralische, emissionsarme Materialien</span></div><div><strong>Präzise</strong><span>sauber, zuverlässig, termingerecht</span></div><div><strong>Individuell</strong><span>Farbton, Oberfläche und Wirkung passend zum Raum</span></div></section>
  <section class="split-section about-preview"><div class="split-media overlap-left"><img src={featureImages.about} alt="Gestaltete Innenfläche von RaumDesign Rudek" loading="lazy" /></div><div class="split-copy"><p class="eyebrow">Philosophie</p><h2>Alte Handwerkstechniken. Moderne Räume.</h2><p>RaumDesign Rudek steht für Gestaltung mit Sinn für Material, Farbe und Atmosphäre. Ob Wand streichen, tapezieren, glätten, sanieren oder exklusive Oberflächen gestalten: Ziel ist ein Raum, der sich richtig anfühlt.</p><p>Die Arbeiten entstehen mit ausgewählten Materialien, handwerklicher Ruhe und einem Blick für das, was zum Kunden und zur Architektur passt.</p><a class="text-link" href="/ueber-uns/">Mehr über Rudek erfahren</a></div></section>
  <section class="services-bento"><div class="section-intro"><p class="eyebrow">Leistungen</p><h2>Von Renovierung bis Wandunikat.</h2></div><article class="service-feature"><img src={featureImages.serviceOne} alt="Hochwertige Wandgestaltung mit mineralischer Oberfläche" loading="lazy" /><div><h3>Kreative Raum- und Wandgestaltung</h3><p>Farbkonzepte, Musterflächen, Kalk- und Marmorputze, Lasuren und Oberflächen, die einem Raum Charakter geben.</p></div></article>{services.slice(1, 7).map((s) => <article class="service-card"><h3>{s}</h3></article>)}</section>
  <section class="material-dark"><div><p class="eyebrow">Materialwirkung</p><h2>Kalkputz kann mehr als schön aussehen.</h2><p>Mineralische Kalkputze sind diffusionsfähig, können Feuchtigkeit aufnehmen und wirken durch ihre Alkalität antibakteriell. Genau deshalb sind Materialkenntnis und saubere Verarbeitung entscheidend.</p></div><div class="material-images"><img src={featureImages.serviceTwo} alt="Stuccotechnik mit Lasur" loading="lazy" /><img src={featureImages.serviceThree} alt="Detail einer gestalteten Oberfläche" loading="lazy" /></div></section>
  <section class="process-section"><p class="eyebrow">Ablauf</p><h2>Beraten, bemustern, sauber ausführen.</h2><ol><li><span>01</span><strong>Beratung</strong><p>Wünsche, Raumwirkung und Anforderungen klären.</p></li><li><span>02</span><strong>Musterfläche</strong><p>Farbe und Oberfläche sichtbar machen, bevor es ernst wird.</p></li><li><span>03</span><strong>Ausführung</strong><p>Staubarm, zuverlässig und mit Blick für Details arbeiten.</p></li></ol></section>
  <section class="gallery-teaser"><div class="section-intro"><p class="eyebrow">Galerie</p><h2>Originale Arbeiten. Keine Stock-Fassade.</h2></div><GalleryGrid limit={12} /><a class="btn secondary" href="/galerie/">Alle Bilder ansehen</a></section>
  <CTA />
</BaseLayout>
